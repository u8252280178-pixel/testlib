-- ================== CUSTOM FONT LOADING ==================
local function LoadCustomFont()
    local fontPath = "MyScriptHub/ProggyClean.ttf"  -- Change if your folder/path is different
    
    if isfile and isfile(fontPath) then
        local success, font = pcall(function()
            return getcustomasset(fontPath) or (getsynasset and getsynasset(fontPath))
        end)
        if success and font then
            return font
        end
    end
    
    -- Fallback to default if font not found
    warn("[Linoria] ProggyClean font not found at: " .. fontPath)
    return Enum.Font.Code
end

